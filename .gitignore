node_modules/
dist/
*.log
.tmp/

# Vitest V8 coverage output (`npm run test:coverage`)
/coverage/

# Default PubsubVoter dataPath (persistent caches) — tests/benches pass `dataPath: false`,
# but a stray local run must never commit its sqlite files.
/.bitsocial-pubsub-voting/

# benchmark/ is TypeScript compiled in place (see benchmark/tsconfig.json); ignore the emitted JS,
# keep the .ts sources and the .mjs orchestrator.
/benchmark/*.js
/benchmark/*.d.ts
/benchmark/*.js.map
