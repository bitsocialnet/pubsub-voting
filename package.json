{
  "name": "@bitsocial/pubsub-votes",
  "version": "0.0.0",
  "description": "Trustless pubsub voting over a shared libp2p/Helia node. Schema + design scaffold (no implementation yet).",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ipld/dag-cbor": "9.2.7",
    "p-limit": "6.2.0",
    "viem": "2.54.0",
    "zod": "4.3.6"
  },
  "peerDependencies": {
    "@libp2p/interface": "3.2.2",
    "helia": "6.1.4",
    "multiformats": "13.4.2"
  },
  "devDependencies": {
    "@libp2p/interface": "3.2.2",
    "@pkcprotocol/pkc-js": "0.0.47",
    "multiformats": "13.4.2",
    "strip-json-comments": "5.0.3",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
