{
  "name": "@bitsocial/pubsub-votes",
  "version": "0.0.0",
  "description": "Trustless pubsub voting over a shared libp2p/Helia node. Schema + design scaffold (no implementation yet).",
  "type": "module",
  "license": "GPL-3.0-or-later",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "browser": {
    "better-sqlite3": false
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:examples": "tsc -p tsconfig.examples.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "build:bench": "tsc -p benchmark/tsconfig.json",
    "bench:cold-join": "node benchmark/run.mjs",
    "bench:directory-load": "node benchmark/run-directory.mjs"
  },
  "dependencies": {
    "@ipld/dag-cbor": "9.2.7",
    "@libp2p/interface": "3.2.4",
    "better-sqlite3": "12.11.1",
    "helia": "6.1.4",
    "multiformats": "13.4.2",
    "p-limit": "6.2.0",
    "viem": "2.54.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@chainsafe/libp2p-noise": "17.0.0",
    "@chainsafe/libp2p-yamux": "8.0.1",
    "@helia/delegated-routing-v1-http-api-client": "6.0.1",
    "@libp2p/fetch": "4.1.7",
    "@libp2p/gossipsub": "16.0.3",
    "@libp2p/identify": "4.1.8",
    "@libp2p/tcp": "11.0.22",
    "@multiformats/multiaddr": "13.0.3",
    "@pkcprotocol/pkc-js": "0.0.63",
    "@types/better-sqlite3": "7.6.13",
    "fake-indexeddb": "6.2.5",
    "libp2p": "3.3.4",
    "strip-json-comments": "5.0.3",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
